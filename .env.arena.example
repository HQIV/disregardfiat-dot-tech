# Copy to /home/ubuntu/disregardfiat-dot-tech/.env.arena on the server (chmod 600).

# Arena API
ARENA_API_PORT=3020
ARENA_API_HOST=127.0.0.1
ARENA_DATA_DIR=/home/ubuntu/disregardfiat-dot-tech/server/data
ARENA_CORS_ORIGIN=https://disregardfiat.tech

# GitHub OAuth App (Settings → Developer settings → OAuth apps)
# Homepage: https://disregardfiat.tech
# Callback:  https://disregardfiat.tech/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://disregardfiat.tech/api/v1/auth/github/callback

PYHQIV_LEADERBOARD_URL=https://raw.githubusercontent.com/HQIV/pyhqiv/main/arena/leaderboard.json
# Optional overrides for baseline seeding when leaderboard.json is still empty:
# PYHQIV_BASELINE_URL=https://raw.githubusercontent.com/HQIV/pyhqiv/main/arena/baseline.json
# PYHQIV_MAIN_COMMIT_URL=https://api.github.com/repos/HQIV/pyhqiv/commits/main

# PayPal Instant Payment Notification (Profile → Instant payment notifications)
# Notification URL: https://disregardfiat.tech/api/v1/paypal/ipn
# PAYPAL_SANDBOX=1
